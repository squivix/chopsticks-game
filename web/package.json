{
  "name": "chopsticks-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Chopsticks hand-game — Vue 3 + Vite single-page app.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "CHOPSTICKS_NO_REMOTE_CPU=1 vite build --base=./",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
